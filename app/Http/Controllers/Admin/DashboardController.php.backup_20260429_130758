<?php

namespace App\Http\Controllers\Admin;

use App\Http\Controllers\Controller;
use Illuminate\Support\Facades\DB;
use Illuminate\View\View;

class DashboardController extends Controller
{
    public function index(): View
    {
        $stats = [
            'pages' => DB::table('pages')->count(),
            'services' => DB::table('services')->count(),
            'posts' => DB::table('posts')->count(),
            'team_members' => DB::table('team_members')->count(),
            'sliders' => DB::table('sliders')->count(),
            'contact_messages' => DB::table('contact_messages')->count(),
            'unread_messages' => DB::table('contact_messages')->where('is_read', 0)->count(),
        ];

        return view('admin.dashboard', compact('stats'));
    }
}
