<script>
    document.addEventListener('DOMContentLoaded', function () {
        function turkishToAscii(value) {
            var map = {
                'ş': 's', 'Ş': 's',
                'ı': 'i', 'İ': 'i',
                'ğ': 'g', 'Ğ': 'g',
                'ü': 'u', 'Ü': 'u',
                'ö': 'o', 'Ö': 'o',
                'ç': 'c', 'Ç': 'c'
            };

            return value.replace(/[şŞıİğĞüÜöÖçÇ]/g, function (char) {
                return map[char] || char;
            });
        }

        function slugify(value) {
            value = String(value || '');
            value = turkishToAscii(value);
            value = value.toLowerCase();
            value = value.replace(/&/g, ' ve ');
            value = value.replace(/[^a-z0-9]+/g, '-');
            value = value.replace(/^-+|-+$/g, '');
            value = value.replace(/-{2,}/g, '-');

            return value;
        }

        function findTitleInput(form) {
            var selectors = [
                'input[name="title"]',
                'input[name="name"]',
                'input[name="menu_title"]',
                'input[name="label"]'
            ];

            for (var i = 0; i < selectors.length; i++) {
                var input = form.querySelector(selectors[i]);

                if (input) {
                    return input;
                }
            }

            return null;
        }

        function findSlugInput(form) {
            var selectors = [
                'input[name="slug"]',
                'input[id="slug"]'
            ];

            for (var i = 0; i < selectors.length; i++) {
                var input = form.querySelector(selectors[i]);

                if (input) {
                    return input;
                }
            }

            return null;
        }

        function currentBaseUrl() {
            return window.location.origin;
        }

        function guessPreviewPrefix() {
            var path = window.location.pathname;

            if (path.indexOf('/admin/services') !== -1) {
                return '/hizmetler/';
            }

            if (path.indexOf('/admin/posts') !== -1) {
                return '/blog/';
            }

            if (path.indexOf('/admin/post-categories') !== -1) {
                return '/blog/kategori/';
            }

            if (path.indexOf('/admin/team-members') !== -1) {
                return '/ekibimiz/';
            }

            return '/';
        }

        function updatePreview(slugInput, previewEl) {
            if (!previewEl) {
                return;
            }

            var slug = slugInput.value || '';
            var prefix = guessPreviewPrefix();

            if (!slug) {
                previewEl.innerHTML = 'Önizleme: <code>-</code>';
                return;
            }

            previewEl.innerHTML = 'Önizleme: <code>' + currentBaseUrl() + prefix + slug + '</code>';
        }

        function setupSlugTool(form) {
            if (!form || form.dataset.autoSlugReady === '1') {
                return;
            }

            var titleInput = findTitleInput(form);
            var slugInput = findSlugInput(form);

            if (!titleInput || !slugInput) {
                return;
            }

            form.dataset.autoSlugReady = '1';

            var originalSlug = slugInput.value || '';
            var isEditPage = originalSlug.trim() !== '';
            var locked = isEditPage;

            slugInput.dataset.autoSlugTouched = isEditPage ? '1' : '0';

            var tools = document.createElement('div');
            tools.className = 'auto-slug-tools';

            var refreshButton = document.createElement('button');
            refreshButton.type = 'button';
            refreshButton.className = 'auto-slug-refresh';
            refreshButton.textContent = 'Slug Yenile';

            var lockButton = document.createElement('button');
            lockButton.type = 'button';
            lockButton.className = 'auto-slug-lock';

            var status = document.createElement('span');
            status.className = 'auto-slug-status';

            var help = document.createElement('small');
            help.className = 'auto-slug-help';
            help.textContent = 'Başlıktan otomatik slug üretir. Türkçe karakterleri dönüştürür, boşlukları tire yapar. Slug alanını elle düzenleyebilirsin.';

            var preview = document.createElement('span');
            preview.className = 'auto-slug-preview';

            function renderStatus() {
                if (locked) {
                    lockButton.textContent = 'Kilidi Aç';
                    status.textContent = 'Slug kilitli';
                    status.classList.add('is-locked');
                } else {
                    lockButton.textContent = 'Slug Kilitle';
                    status.textContent = 'Otomatik slug aktif';
                    status.classList.remove('is-locked');
                }

                updatePreview(slugInput, preview);
            }

            function generateSlug(force) {
                if (locked && !force) {
                    return;
                }

                var generated = slugify(titleInput.value);

                if (!generated) {
                    return;
                }

                slugInput.value = generated;
                slugInput.dispatchEvent(new Event('input', { bubbles: true }));
                slugInput.dispatchEvent(new Event('change', { bubbles: true }));
                updatePreview(slugInput, preview);
            }

            refreshButton.addEventListener('click', function () {
                var generated = slugify(titleInput.value);

                if (!generated) {
                    alert('Slug üretmek için önce başlık alanını doldur.');
                    return;
                }

                slugInput.value = generated;
                slugInput.dataset.autoSlugTouched = '1';
                slugInput.dispatchEvent(new Event('input', { bubbles: true }));
                slugInput.dispatchEvent(new Event('change', { bubbles: true }));
                updatePreview(slugInput, preview);
            });

            lockButton.addEventListener('click', function () {
                locked = !locked;
                renderStatus();
            });

            titleInput.addEventListener('input', function () {
                if (slugInput.dataset.autoSlugTouched === '0' && !locked) {
                    generateSlug(false);
                }
            });

            slugInput.addEventListener('input', function () {
                var normalized = slugify(slugInput.value);

                if (slugInput.value !== normalized) {
                    var cursorPosition = slugInput.selectionStart || slugInput.value.length;
                    slugInput.value = normalized;
                    try {
                        slugInput.setSelectionRange(cursorPosition, cursorPosition);
                    } catch (e) {}
                }

                slugInput.dataset.autoSlugTouched = slugInput.value ? '1' : '0';
                updatePreview(slugInput, preview);
            });

            form.addEventListener('submit', function () {
                slugInput.value = slugify(slugInput.value || titleInput.value);
            });

            tools.appendChild(refreshButton);
            tools.appendChild(lockButton);
            tools.appendChild(status);

            slugInput.insertAdjacentElement('afterend', preview);
            preview.insertAdjacentElement('afterend', help);
            help.insertAdjacentElement('afterend', tools);

            if (!isEditPage && !slugInput.value && titleInput.value) {
                generateSlug(true);
            }

            renderStatus();
        }

        document.querySelectorAll('form').forEach(function (form) {
            setupSlugTool(form);
        });
    });
</script>
<!-- auto-slug-script-end -->
